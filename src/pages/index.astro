---
import Base from '@layouts/Base.astro';
import Hero from '@components/home/Hero.astro';
import StatsBar from '@components/home/StatsBar.astro';
import CategoryGrid from '@components/home/CategoryGrid.astro';
import FeaturedAPIs from '@components/home/FeaturedAPIs.astro';
import { getAllAPIs, getAllCategories, getSiteStats } from '@lib/getApis';
import { getBaseUrl } from '@lib/utils';

const stats = getSiteStats();
const categories = getAllCategories();
const allAPIs = getAllAPIs();
const base = getBaseUrl();

// Select 6 diverse featured APIs from different categories
const featured = categories
  .slice(0, 6)
  .map((cat) => cat.apis[0])
  .filter((api): api is NonNullable<typeof api> => api !== undefined);

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'API Hub',
  url: `https://beko2210.github.io${base}`,
  description: 'A curated directory of free public APIs for developers.',
  potentialAction: {
    '@type': 'SearchAction',
    target: `https://beko2210.github.io${base}/search?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
});
---

<Base
  title="API Hub"
  description="Browse, search and filter 1,400+ free public APIs across 50+ categories. The most complete directory of open APIs for developers."
  jsonLd={jsonLd}
>
  <Hero stats={stats} />
  <StatsBar stats={stats} />
  <CategoryGrid categories={categories} />
  <FeaturedAPIs apis={featured} />

  <!-- CTA Section -->
  <section style="padding: 3rem 0;">
    <div
      class="container"
      style="
        max-width: 640px;
        text-align: center;
        padding: 2.5rem;
        background: var(--surface);
        border-radius: var(--r-xl);
        border: 1px solid var(--border);
      "
    >
      <h2
        style="
          font-size: 1.25rem;
          font-weight: 700;
          color: var(--text-1);
          margin: 0 0 0.75rem;
        "
      >
        Want to add your API?
      </h2>
      <p style="font-size: 0.9375rem; color: var(--text-3); margin: 0 0 1.25rem;">
        Contribute to the open-source public-apis repository to get your API listed here.
      </p>
      <a
        href="https://github.com/public-apis/public-apis"
        target="_blank"
        rel="noopener noreferrer"
        style="
          display: inline-flex;
          align-items: center;
          gap: 0.5rem;
          padding: 0.625rem 1.25rem;
          background: var(--accent);
          color: white;
          border-radius: var(--r-md);
          font-weight: 600;
          font-size: 0.875rem;
          text-decoration: none;
          transition: background var(--t-fast);
        "
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
        </svg>
        Submit on GitHub
      </a>
    </div>
  </section>
</Base>
