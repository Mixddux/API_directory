---
import Base from '@layouts/Base.astro';
import Hero from '@components/home/Hero.astro';
import StatsBar from '@components/home/StatsBar.astro';
import CategoryGrid from '@components/home/CategoryGrid.astro';
import FeaturedAPIs from '@components/home/FeaturedAPIs.astro';
import { getAllAPIs, getAllCategories, getSiteStats } from '@lib/getApis';
import { getBaseUrl } from '@lib/utils';

const stats = getSiteStats();
const categories = getAllCategories();
const allAPIs = getAllAPIs();
const base = getBaseUrl();

// Hand-picked popular APIs from diverse categories
const featuredNames = [
  'GitHub',
  'Spotify',
  'OpenWeatherMap',
  'NASA',
  'REST Countries',
  'JSONPlaceholder',
  'CoinGecko',
  'Unsplash',
];

const featured = featuredNames
  .map((name) => allAPIs.find((api) => api.name === name))
  .filter((api): api is NonNullable<typeof api> => api !== undefined);

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'API Hub',
  url: `https://beko2210.github.io${base}`,
  description: 'A curated directory of free public APIs for developers.',
  potentialAction: {
    '@type': 'SearchAction',
    target: `https://beko2210.github.io${base}/search?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
});
---

<Base
  title="API Hub"
  description="Browse, search and filter 1,400+ free public APIs across 50+ categories. The most complete directory of open APIs for developers."
  jsonLd={jsonLd}
>
  <Hero stats={stats} />
  <StatsBar stats={stats} />
  <CategoryGrid categories={categories} />
  <FeaturedAPIs apis={featured} />

  <!-- CTA Section -->
  <section style="padding: 3rem 0;">
    <div
      class="container"
      style="
        max-width: 640px;
        text-align: center;
        padding: 2.5rem;
        background: var(--surface);
        border-radius: var(--r-xl);
        border: 1px solid var(--border);
      "
    >
      <h2
        style="
          font-size: 1.25rem;
          font-weight: 700;
          color: var(--text-1);
          margin: 0 0 0.75rem;
        "
      >
        Want to add your API?
      </h2>
      <p style="font-size: 0.9375rem; color: var(--text-3); margin: 0 0 1.25rem;">
        Submit a new free public API via our issue form — it gets added automatically on the next build.
      </p>
      <a
        href={`${base}/submit`}
        style="
          display: inline-flex;
          align-items: center;
          gap: 0.5rem;
          padding: 0.625rem 1.25rem;
          background: var(--text-1);
          color: var(--bg);
          border-radius: var(--r-md);
          font-weight: 600;
          font-size: 0.875rem;
          text-decoration: none;
          transition: background var(--t-fast);
        "
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14M5 12h14"/>
        </svg>
        Submit an API
      </a>
    </div>
  </section>
</Base>
