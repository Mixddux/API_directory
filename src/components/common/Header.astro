---
import ThemeToggle from './ThemeToggle.astro';
import { getBaseUrl } from '@lib/utils';

const base = getBaseUrl();
const currentPath = Astro.url.pathname;

const navLinks = [
  {
    label: 'Categories',
    href: '/',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>`,
  },
  {
    label: 'Search',
    href: '/search',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
  },
  {
    label: 'Submit',
    href: '/submit',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14"/></svg>`,
  },
];
---

<header class="site-header">
  <div class="header-inner">
    <!-- Logo -->
    <a href={`${base}/`} class="logo-link">
      <svg width="28" height="28" viewBox="0 0 40 40" style="flex-shrink: 0;" aria-hidden="true" role="img">
        <rect width="40" height="40" rx="8" fill="#09090b"/>
        <text x="20" y="27" text-anchor="middle" font-family="system-ui, -apple-system, sans-serif" font-weight="800" font-size="16" fill="#ffffff" letter-spacing="-0.5">API</text>
      </svg>
      <span class="logo-text">Hub</span>
    </a>

    <!-- Desktop Nav (text links, hidden on mobile) -->
    <nav class="desktop-nav" aria-label="Main navigation">
      {
        navLinks.map((link) => {
          const fullHref = `${base}${link.href}`;
          const isActive = currentPath === fullHref || currentPath === `${fullHref}/`;
          return (
            <a
              href={fullHref}
              class:list={['nav-link', { active: isActive }]}
              {...(isActive ? { 'aria-current': 'page' } : {})}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <!-- Mobile Nav (icon-only, hidden on desktop) -->
    <nav class="mobile-nav" aria-label="Main navigation">
      {
        navLinks.map((link) => {
          const fullHref = `${base}${link.href}`;
          const isActive = currentPath === fullHref || currentPath === `${fullHref}/`;
          return (
            <a
              href={fullHref}
              aria-label={link.label}
              title={link.label}
              class:list={['mobile-nav-icon', { active: isActive }]}
              {...(isActive ? { 'aria-current': 'page' } : {})}
            >
              <Fragment set:html={link.icon} />
            </a>
          );
        })
      }
    </nav>

    <!-- Right side -->
    <div class="header-actions">
      <ThemeToggle />
      <a
        href="https://github.com/BEKO2210/API_directory"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub repository"
        class="github-link"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
        </svg>
      </a>
    </div>
  </div>
</header>

<style is:global>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--header-h);
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .site-header .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 1rem;
    max-width: 1200px;
    margin: 0 auto;
    gap: 0.5rem;
  }

  .site-header .logo-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--text-1);
    text-decoration: none;
    flex-shrink: 0;
    min-height: auto;
    min-width: auto;
  }

  .site-header .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-3);
    text-decoration: none;
    transition: color 0.15s;
    min-height: auto;
    min-width: auto;
  }

  .site-header .nav-link.active {
    color: var(--text-1);
  }

  .site-header .header-actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  .site-header .github-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    min-height: 36px;
    min-width: 36px;
    border-radius: var(--r-md);
    border: 1px solid var(--border);
    color: var(--text-2);
    transition: background 0.2s, color 0.2s;
  }

  .site-header .mobile-nav-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    min-height: 44px;
    min-width: 44px;
    border-radius: var(--r-md);
    color: var(--text-3);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }

  .site-header .mobile-nav-icon.active {
    color: var(--accent);
  }

  .site-header .mobile-nav-icon:active {
    background: var(--surface);
  }

  /* DEFAULT: Mobile layout (mobile-first) */
  .site-header .desktop-nav {
    display: none;
  }

  .site-header .mobile-nav {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .site-header .logo-text {
    display: none;
  }

  /* DESKTOP: 768px and up — show text nav, hide icon nav */
  @media (min-width: 768px) {
    .site-header .desktop-nav {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .site-header .mobile-nav {
      display: none;
    }

    .site-header .logo-text {
      display: inline;
    }
  }
</style>
