---
import { getBaseUrl } from '@lib/utils';

const base = getBaseUrl();
const year = new Date().getFullYear();
---

<footer
  style="
    border-top: 1px solid var(--border);
    background: var(--surface);
    padding: 3rem 0 2rem;
    margin-top: 4rem;
  "
>
  <div class="container">
    <div
      style="
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 2rem;
        margin-bottom: 2rem;
      "
    >
      <!-- Brand -->
      <div>
        <p style="font-weight: 700; font-size: 1.125rem; color: var(--text-1); margin: 0 0 0.5rem;">
          API Hub
        </p>
        <p style="font-size: 0.875rem; color: var(--text-3); margin: 0; line-height: 1.6;">
          A curated directory of free public APIs for developers. Updated daily from the open-source community.
        </p>
      </div>

      <!-- Links -->
      <div>
        <p style="font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-4); margin: 0 0 0.75rem;">
          Navigate
        </p>
        <nav style="display: flex; flex-direction: column; gap: 0.5rem;">
          <a href={`${base}/`} style="font-size: 0.875rem; color: var(--text-3); text-decoration: none;">Home</a>
          <a href={`${base}/search`} style="font-size: 0.875rem; color: var(--text-3); text-decoration: none;">Search</a>
          <a href={`${base}/submit`} style="font-size: 0.875rem; color: var(--text-3); text-decoration: none;">Submit API</a>
          <a href={`${base}/about`} style="font-size: 0.875rem; color: var(--text-3); text-decoration: none;">About</a>
        </nav>
      </div>

      <!-- Resources -->
      <div>
        <p style="font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-4); margin: 0 0 0.75rem;">
          Resources
        </p>
        <nav style="display: flex; flex-direction: column; gap: 0.5rem;">
          <a href="https://github.com/public-apis/public-apis" target="_blank" rel="noopener noreferrer" style="font-size: 0.875rem; color: var(--text-3); text-decoration: none;">public-apis Repository</a>
          <a href={`${base}/rss.xml`} style="font-size: 0.875rem; color: var(--text-3); text-decoration: none;">RSS Feed</a>
          <a href={`${base}/privacy`} style="font-size: 0.875rem; color: var(--text-3); text-decoration: none;">Privacy Policy</a>
        </nav>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      style="
        border-top: 1px solid var(--border);
        padding-top: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
      "
    >
      <p style="font-size: 0.75rem; color: var(--text-4); margin: 0;">
        &copy; {year} API Hub. Data sourced from <a href="https://github.com/public-apis/public-apis" target="_blank" rel="noopener noreferrer" style="color: var(--text-3);">public-apis</a>. MIT License.
      </p>
      <a
        href="https://github.com/BEKO2210/API_directory"
        target="_blank"
        rel="noopener noreferrer"
        style="
          display: inline-flex;
          align-items: center;
          gap: 0.375rem;
          font-size: 0.75rem;
          color: var(--text-4);
          text-decoration: none;
        "
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
        </svg>
        Star on GitHub
      </a>
    </div>
  </div>
</footer>
