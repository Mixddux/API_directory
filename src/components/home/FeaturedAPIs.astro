---
import type { API } from '@lib/types';
import APICard from '@components/api/APICard.astro';
import { getBaseUrl } from '@lib/utils';

interface Props {
  apis: API[];
}

const { apis } = Astro.props;
const base = getBaseUrl();
---

<section style="padding: 3rem 0;">
  <div class="container">
    <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.5rem;">
      <div>
        <h2
          style="
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-1);
            margin: 0 0 0.25rem;
          "
        >
          Featured APIs
        </h2>
        <p style="font-size: 0.875rem; color: var(--text-3); margin: 0;">
          Popular APIs loved by developers
        </p>
      </div>
      <a
        href={`${base}/search`}
        style="
          font-size: 0.875rem;
          font-weight: 500;
          color: var(--text-3);
          text-decoration: none;
          display: inline-flex;
          align-items: center;
          gap: 0.25rem;
        "
      >
        View all
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </a>
    </div>
    <div
      style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1rem;
      "
    >
      {apis.map((api) => <APICard api={api} />)}
    </div>
  </div>
</section>
